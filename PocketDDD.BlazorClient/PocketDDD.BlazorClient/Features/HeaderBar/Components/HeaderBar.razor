@using PocketDDD.BlazorClient.Features.HeaderBar.Store;

@inherits Fluxor.Blazor.Web.Components.FluxorComponent

@inject IDispatcher Dispatcher
@inject IState<HeaderBarState> State

<MudAppBar Color="Color.Primary">
    @if (State.Value.ShowBackButton)
    {
        <MudIconButton 
            Icon="@Icons.Material.Filled.ArrowBack"
            Edge="Edge.Start"
            Color="Color.Inherit"
            OnClick="HandleNavigateBack"/>
    }

    <MudText Typo="Typo.h5">@State.Value.Title</MudText>
    <MudSpacer />
    <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@OpenDrawer"/>
</MudAppBar>
<MudDrawer @bind-Open="@_open">
    <MudDrawerHeader>
        <MudText Typo="Typo.h6">Pocket DDD</MudText>
    </MudDrawerHeader>
    <MudNavMenu>
        <MudNavLink Match="NavLinkMatch.All" Href="/" Icon="@Icons.Material.Outlined.Home">Home</MudNavLink>
        @if (State.Value.ShowFeedbackButton)
        {
            <MudNavLink Match="NavLinkMatch.All" OnClick="@HandleShowFeedback" Icon="@Icons.Material.Filled.TagFaces">
                @(State.Value.ShowBackButton ? "Session feedback" : "Event feedback")
            </MudNavLink>
        }
        <MudNavLink Href="https://dddsouthwest.com/venue-layout" Icon="@Icons.Material.Outlined.Map">Venue map</MudNavLink>
    </MudNavMenu>
</MudDrawer>

@code { 
    private bool _open;

    private void OpenDrawer()
    {
        _open = true;
    }
    
    void HandleShowFeedback() => Dispatcher.Dispatch(new ViewFeedbackAction());
    void HandleNavigateBack() => Dispatcher.Dispatch(new NavigateBackAction());
}
